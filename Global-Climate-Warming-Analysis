{"metadata":{"kernelspec":{"language":"python","display_name":"Python 3","name":"python3"},"language_info":{"name":"python","version":"3.12.13","mimetype":"text/x-python","codemirror_mode":{"name":"ipython","version":3},"pygments_lexer":"ipython3","nbconvert_exporter":"python","file_extension":".py"},"kaggle":{"accelerator":"none","dataSources":[{"sourceType":"datasetVersion","sourceId":2150}],"dockerImageVersionId":31400,"isInternetEnabled":true,"language":"python","sourceType":"notebook","isGpuEnabled":false}},"nbformat_minor":4,"nbformat":4,"cells":[{"cell_type":"markdown","source":"This project analyzes the Berkeley Earth Global Surface Temperature Dataset from Kaggle, covering monthly global temperature records spanning 1750–2015. We explore long-term warming trends, temperature anomalies, seasonal differences, max/min land temperature divergence, correlation between measurement uncertainty and temperature values, and deliver both static Matplotlib/Seaborn charts and interactive Plotly visualizations.","metadata":{}},{"cell_type":"markdown","source":"**Core research objectives:**\n\n1. Track global land & combined land-ocean temperature evolution over 265 years\n2. Quantify temperature anomalies using the 1951–1980 climate baseline\n3. Compare warming rates of maximum and minimum land temperatures\n4. Analyze seasonal warming disparities across winter, spring, summer, autumn\n5. Examine distribution of monthly temperature anomalies by decade\n6. Calculate correlation between raw temperature readings and measurement uncertainty\n7. Build interactive time-series dashboards for dynamic temperature trend exploration\n\nDataset file used: GlobalTemperatures.csv","metadata":{}},{"cell_type":"code","source":"import os\nimport pandas as pd\nimport numpy as np\nimport matplotlib.pyplot as plt\nimport seaborn as sns\nfrom scipy import stats\nfrom sklearn.preprocessing import MinMaxScaler\nfrom matplotlib.colors import TwoSlopeNorm\nimport plotly.express as px\nimport plotly.graph_objects as go\n\n# Global Plot Configuration\nplt.style.use('seaborn-v0_8-whitegrid')\nsns.set_context(\"paper\", font_scale=1.2)\nplt.rcParams['font.sans-serif'] = ['DejaVu Sans']\nplt.rcParams['axes.unicode_minus'] = False\n\n# Define two candidate paths\nkaggle_path = \"/kaggle/input/datasets/organizations/berkeleyearth/climate-change-earth-surface-temperature-data/GlobalTemperatures.csv\"\n\n# Auto-select valid path\nif os.path.exists(kaggle_path):\n    df = pd.read_csv(kaggle_path)\n    print(\"✅ Loaded dataset from Kaggle mounted input folder\")\nelif os.path.exists(local_path):\n    df = pd.read_csv(local_path)\n    print(\"✅ Loaded dataset from local GitHub download folder\")\nelse:\n    raise FileNotFoundError(\n        \"❌ Dataset file missing! \"\n        \"Kaggle users: Attach 'climate-change-earth-surface-temperature-data' via Add Data sidebar. \"\n        \"Local users: Unzip dataset into project root folder.\"\n    )\n\n# Parse date & extract year/month\ndf['dt'] = pd.to_datetime(df['dt'])\ndf['Year'] = df['dt'].dt.year\ndf['Month'] = df['dt'].dt.month\n\n# 1. Basic Data Inspection & Missing Value Analysis\n\nprint(\"===== Dataset Basic Info =====\")\nprint(df.info())\nprint(\"\\n===== Statistical Description =====\")\nprint(df.describe())\nprint(\"\\n===== Missing Value Count per Column =====\")\nprint(df.isnull().sum())\n\n# Linear Interpolation for missing temperature records\ndf = df.interpolate(method='linear')\n\n# Filter post-1850 data (reliable instrumental temperature records)\ndf_recent = df[df[\"Year\"] >= 1850].copy()\n\n# Aggregate yearly average temperatures\nyear_df = df_recent.groupby(\"Year\").agg({\n    \"LandAverageTemperature\": \"mean\",\n    \"LandMaxTemperature\": \"mean\",\n    \"LandMinTemperature\": \"mean\",\n    \"LandAndOceanAverageTemperature\": \"mean\",\n    \"LandAndOceanAverageTemperatureUncertainty\": \"mean\"\n}).reset_index()\n\n# 2. Calculate Temperature Anomalies (1951–1980 Baseline Standard)\n\n# Global monthly baseline (eliminate seasonal bias)\nmonthly_baseline = df[(df['Year'] >= 1951) & (df['Year'] <= 1980)].groupby('Month')['LandAndOceanAverageTemperature'].mean()\ndf_recent['Monthly_Anomaly'] = df_recent.apply(\n    lambda row: row['LandAndOceanAverageTemperature'] - monthly_baseline.get(row['Month'], np.nan), axis=1\n)\n\n# Annual temperature anomaly for climate stripes\nglobal_mean_temp = year_df[\"LandAndOceanAverageTemperature\"].mean()\nyear_df[\"Temp_Anomaly\"] = year_df[\"LandAndOceanAverageTemperature\"] - global_mean_temp\n\n# Flag extreme temperature months (Z-score outlier detection)\ndf_recent[\"temp_zscore\"] = stats.zscore(df_recent[\"Monthly_Anomaly\"])\ndf_recent[\"is_extreme\"] = np.where(np.abs(df_recent[\"temp_zscore\"]) > 2, True, False)\nprint(f\"\\nCount of extreme temperature months (|Z-score|>2): {df_recent['is_extreme'].sum()}\")\n\n# Min-Max Normalization for temperature values\nscaler = MinMaxScaler()\nnorm_cols = [\"LandAverageTemperature\", \"LandAndOceanAverageTemperature\"]\ndf_recent[[\"Norm_LandTemp\", \"Norm_LandOceanTemp\"]] = scaler.fit_transform(df_recent[norm_cols])\n\n# Create decade label for boxplot grouping\ndf_recent['Decade'] = (df_recent['Year'] // 10 * 10).astype(str) + 's'","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-06-25T03:01:38.206245Z","iopub.execute_input":"2026-06-25T03:01:38.20647Z","iopub.status.idle":"2026-06-25T03:01:43.027783Z","shell.execute_reply.started":"2026-06-25T03:01:38.206436Z","shell.execute_reply":"2026-06-25T03:01:43.026919Z"}},"outputs":[{"name":"stdout","text":"✅ Loaded dataset from Kaggle mounted input folder\n===== Dataset Basic Info =====\n<class 'pandas.core.frame.DataFrame'>\nRangeIndex: 3192 entries, 0 to 3191\nData columns (total 11 columns):\n #   Column                                     Non-Null Count  Dtype         \n---  ------                                     --------------  -----         \n 0   dt                                         3192 non-